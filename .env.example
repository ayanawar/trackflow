# Database — PostgreSQL for production (Neon/Railway/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/trackflow

# JWT — generate a strong random secret (32+ chars)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Google signup setup-token TTL (seconds). Short-lived token issued by
# POST /api/auth/google and consumed by POST /api/auth/google/complete.
# Default 600 = 10 minutes. See spec 009-org-workspace-signup R3.
GOOGLE_SETUP_TOKEN_TTL_SECONDS=600

# App URL (must be HTTPS in production — required by Google OAuth)
NEXTAUTH_URL=https://your-app.vercel.app
NODE_ENV=production

# Google OAuth — public Client ID (not a secret; safe to expose in browser)
# Get this from https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gemini AI — free tier key for AI Insights feature
# Get a free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
